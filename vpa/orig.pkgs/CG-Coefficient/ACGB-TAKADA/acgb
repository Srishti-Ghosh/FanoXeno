        DO 202 I=1,NDE                                                  ACGB5453
        CCDE(I)=CDE(I)                                                  ACGB5454
  202   CONTINUE                                                        ACGB5455
      END IF                                                            ACGB5456
C                                                                       ACGB5457
        NCCHH=NPHJ                                                      ACGB5458
      IF(NPHJ.NE.0) THEN                                                ACGB5459
        DO 1202 I=1,NCCHH                                               ACGB5460
        CCHH(I)=CPHJ(I)                                                 ACGB5461
 1202   CONTINUE                                                        ACGB5462
