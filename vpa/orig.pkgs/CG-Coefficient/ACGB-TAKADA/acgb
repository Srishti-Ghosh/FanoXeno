      COMMON/WWW1/ MCHECK(999),ICHECK(999)                              ACGB5408
C                                                                       ACGB5409
      DIMENSION C1J(6),CC1J(6)                                          ACGB5410
      DIMENSION C2J(6),CC2J(6)                                          ACGB5411
      DIMENSION C3J(6),CC3J(6)                                          ACGB5412
      DIMENSION CCNU(50),CCDE(50)                                       ACGB5413
      DIMENSION CCHH(999)                                               ACGB5414
C                                                                       ACGB5415
C                                                                       ACGB5416
 2000 CONTINUE                                                          ACGB5417
C                                                                       ACGB5418
      CALL READEL                                                       ACGB5419
C                                                                       ACGB5420
      CALL RENUDE                                                       ACGB5421
C                                                                       ACGB5422
      CALL DELTAS                                                       ACGB5423
C                                                                       ACGB5424
      CALL READEL                                                       ACGB5425
C                                                                       ACGB5426
      CALL RENUDE                                                       ACGB5427
C                                                                       ACGB5428
C                                                                       ACGB5429
C   ***** SUMMATION BY USING THE DEFINITION OF 9-J SYMBOL ************  ACGB5430
C                                                                       ACGB5431
C                                                                       ACGB5432
      IF(NTOT(NSUMJ,ISUMF).LT.1) RETURN                                 ACGB5433
      IF(NTOT(N6J,I6JF).LT.3) RETURN                                    ACGB5434
C                                                                       ACGB5435
      DO 2010 K=1,NSUMJ                                                 ACGB5436
      IF(ISUMF(K).EQ.0) GO TO 2010                                      ACGB5437
      CJ=CSUMJ(K)                                                       ACGB5438
C                                                                       ACGB5439
      L1FIND=0                                                          ACGB5440
      L2FIND=0                                                          ACGB5441
      L3FIND=0                                                          ACGB5442
C                                                                       ACGB5443
        NNNU=NNU                                                        ACGB5444
      IF(NNU.NE.0) THEN                                                 ACGB5445
        DO 201 I=1,NNU                                                  ACGB5446
        CCNU(I)=CNU(I)                                                  ACGB5447
  201   CONTINUE                                                        ACGB5448
      END IF                                                            ACGB5449
