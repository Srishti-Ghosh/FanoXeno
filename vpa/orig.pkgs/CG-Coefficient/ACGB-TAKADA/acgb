      C6J(N6J,1)=CJ1                                                    ACGB5338
      C6J(N6J,2)=CJ2                                                    ACGB5339
      C6J(N6J,3)=CJ                                                     ACGB5340
      C6J(N6J,4)=CJ1DD                                                  ACGB5341
      C6J(N6J,5)=CJ2DD                                                  ACGB5342
      C6J(N6J,6)=CK1                                                    ACGB5343
