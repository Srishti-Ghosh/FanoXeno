C                                                                       ACGB5763
      DO 10 I=1,NPHJ                                                    ACGB5764
      IF(MCHECK(I).EQ.0) GO TO 10                                       ACGB5765
      CJ1=CPHW(I)                                                       ACGB5766
      III=1                                                             ACGB5767
C                                                                       ACGB5768
      DO 20 II=1,NPHJ                                                   ACGB5769
      IF(MCHECK(II).EQ.0) GO TO 20                                      ACGB5770
      IF(II.EQ.I) GO TO 20                                              ACGB5771
      IF(CPHW(II).EQ.CJ1) THEN                                          ACGB5772
        III=III+1                                                       ACGB5773
        MCHECK(II)=0                                                    ACGB5774
      ELSEIF(CPHW(II).EQ.CHSIGN(CJ1)) THEN                              ACGB5775
        III=III-1                                                       ACGB5776
        MCHECK(II)=0                                                    ACGB5777
      END IF                                                            ACGB5778
   20 CONTINUE                                                          ACGB5779
C                                                                       ACGB5780
      MN1=MOD(III,4)                                                    ACGB5781
      IF(MN1.LT.0) MN1=MN1+4                                            ACGB5782
      IF(MN1.EQ.0) THEN                                                 ACGB5783
        ICHECK(I)=0                                                     ACGB5784
      ELSEIF(MN1.EQ.1) THEN                                             ACGB5785
        CPHW(I)=CJ1                                                     ACGB5786
        ICHECK(I)=1                                                     ACGB5787
      ELSEIF(MN1.EQ.2) THEN                                             ACGB5788
        CPHW(I)=CJ1                                                     ACGB5789
        ICHECK(I)=2                                                     ACGB5790
