C   *** TO CHECK AND REARRANGE PHASE(J)                                 ACGB5617
C                                                                       ACGB5618
      DO 259 I=1,NPHJ                                                   ACGB5619
      MCHECK(I)=1                                                       ACGB5620
  259 CONTINUE                                                          ACGB5621
C                                                                       ACGB5622
      III1=0                                                            ACGB5623
      DO 260 I=1,NPHJ                                                   ACGB5624
