      NTIME=NTIME+1                                                     ACGB5694
      GO TO 2000                                                        ACGB5695
C                                                                       ACGB5696
 2020 CONTINUE                                                          ACGB5697
C                                                                       ACGB5698
        NNU=NNNU                                                        ACGB5699
      IF(NNU.NE.0) THEN                                                 ACGB5700
        DO 301 I=1,NNU                                                  ACGB5701
        CNU(I)=CCNU(I)                                                  ACGB5702
  301   CONTINUE                                                        ACGB5703
      END IF                                                            ACGB5704
C                                                                       ACGB5705
        NDE=NNDE                                                        ACGB5706
      IF(NDE.NE.0) THEN                                                 ACGB5707
        DO 302 I=1,NDE                                                  ACGB5708
        CDE(I)=CCDE(I)                                                  ACGB5709
  302   CONTINUE                                                        ACGB5710
      END IF                                                            ACGB5711
C                                                                       ACGB5712
      NPHJ=NCCHH                                                        ACGB5713
      IF(NPHJ.NE.0) THEN                                                ACGB5714
        DO 1302 I=1,NPHJ                                                ACGB5715
        CPHJ(I)=CCHH(I)                                                 ACGB5716
 1302   CONTINUE                                                        ACGB5717
      END IF                                                            ACGB5718
C                                                                       ACGB5719
 2010 CONTINUE                                                          ACGB5720
C                                                                       ACGB5721
      RETURN                                                            ACGB5722
      END                                                               ACGB5723
