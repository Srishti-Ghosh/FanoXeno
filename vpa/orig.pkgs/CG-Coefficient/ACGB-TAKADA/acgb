      IF(N9J.NE.0) THEN                                                 ACGB5608
        DO 257 L=1,N9J                                                  ACGB5609
        IF(I9JF(L).EQ.0) GO TO 257                                      ACGB5610
        DO 258 KJ=1,9                                                   ACGB5611
        IF(CJ.EQ.C9J(L,KJ)) GO TO 2020                                  ACGB5612
  258   CONTINUE                                                        ACGB5613
  257   CONTINUE                                                        ACGB5614
      END IF                                                            ACGB5615
