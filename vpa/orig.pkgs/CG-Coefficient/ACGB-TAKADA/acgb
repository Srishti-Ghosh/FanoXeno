C   ***** SUMMATION BY USING THE DEFINITION OF 9-J SYMBOL ************  ACGB5385
C                                                                       ACGB5386
C                                                                       ACGB5387
      SUBROUTINE NINEJ                                                  ACGB5388
C                                                                       ACGB5389
      IMPLICIT CHARACTER*10(C,H)                                        ACGB5390
C                                                                       ACGB5391
      COMMON/SSS1/ NSUMJ,    NPHJ,     NDELJ,      NNU,    N6J          ACGB5392
      COMMON/SSS2/ CSUMJ(50),CPHJ(999),CDELJ(50,2),CNU(50),C6J(50,6)    ACGB5393
