C ***** RANDOM ORDERING OF CSUMM(I) **********************************  ACGB3137
C                                                                       ACGB3138
C                                                                       ACGB3139
      SUBROUTINE SUMJUN(NRPT)                                           ACGB3140
C                                                                       ACGB3141
      IMPLICIT CHARACTER*10(C,H)                                        ACGB3142
C                                                                       ACGB3143
      COMMON/CCC1/ NSUMM,    NPHJ,     NPHM,     NDELM,      NCG        ACGB3144
      COMMON/CCC2/ CSUMM(50),CPHJ(999),CPHM(999),CDELM(50,2),CCG(50,3,2)ACGB3145
C                                                                       ACGB3146
      DIMENSION JUN(50)                                                 ACGB3147
      DIMENSION HSUMM(50)                                               ACGB3148
C                                                                       ACGB3149
      DO 1 I=1,NSUMM                                                    ACGB3150
      HSUMM(I)=CSUMM(I)                                                 ACGB3151
    1 CONTINUE                                                          ACGB3152
C                                                                       ACGB3153
      AN=NRPT                                                           ACGB3154
      A=3.141596*SQRT(AN)                                               ACGB3155
      KKK=0                                                             ACGB3156
      DO 10 K=1,15000                                                   ACGB3157
      A=SQRT(A+1.17+K)                                                  ACGB3158
      IA=A                                                              ACGB3159
      B=A-IA                                                            ACGB3160
      IB=10000.0*B                                                      ACGB3161
      IIB=MOD(IB,NSUMM)+1                                               ACGB3162
      IF(KKK.NE.0) THEN                                                 ACGB3163
        DO 11 I=1,KKK                                                   ACGB3164
        IF(IIB.EQ.JUN(I)) GO TO 10                                      ACGB3165
   11   CONTINUE                                                        ACGB3166
      END IF                                                            ACGB3167
      KKK=KKK+1                                                         ACGB3168
      JUN(KKK)=IIB                                                      ACGB3169
      IF(KKK.GE.NSUMM) GO TO 2                                          ACGB3170
   10 CONTINUE                                                          ACGB3171
C                                                                       ACGB3172
    2 CONTINUE                                                          ACGB3173
      DO 3 K=1,NSUMM                                                    ACGB3174
      CSUMM(K)=HSUMM(JUN(K))                                            ACGB3175
    3 CONTINUE                                                          ACGB3176
C                                                                       ACGB3177
      RETURN                                                            ACGB3178
      END                                                               ACGB3179
