   10 CONTINUE                                                          ACGB5795
C                                                                       ACGB5796
      DO 30 I=1,NPHJ                                                    ACGB5797
      IF(CPHW(I)(1:1).EQ.'0') MCHECK(I)=0                               ACGB5798
      IF(CPHW(I)(1:2).EQ.'-0') MCHECK(I)=0                              ACGB5799
   30 CONTINUE                                                          ACGB5800
C                                                                       ACGB5801
      III=0                                                             ACGB5802
      DO 40 I=1,NPHJ                                                    ACGB5803
      IF(MCHECK(I).EQ.0) GO TO 40                                       ACGB5804
      IF(ICHECK(I).EQ.0) THEN                                           ACGB5805
        GO TO 40                                                        ACGB5806
      ELSEIF(ICHECK(I).EQ.1) THEN                                       ACGB5807
        III=III+1                                                       ACGB5808
        CPHJ(III)=CPHW(I)                                               ACGB5809
      ELSEIF(ICHECK(I).EQ.2) THEN                                       ACGB5810
        III=III+1                                                       ACGB5811
        CPHJ(III)=CPHW(I)                                               ACGB5812
        III=III+1                                                       ACGB5813
        CPHJ(III)=CPHW(I)                                               ACGB5814
      END IF                                                            ACGB5815
   40 CONTINUE                                                          ACGB5816
      NPHJ=III                                                          ACGB5817
C                                                                       ACGB5818
      RETURN                                                            ACGB5819
      END                                                               ACGB5820
