      CALL SYM6JA(I,C1J,CC1J)                                           ACGB5471
      IF(CC1J(6).EQ.CJ) GO TO 220                                       ACGB5472
      CALL SYM6JA(I,C1J,CC1J)                                           ACGB5473
      CALL SYM6JB(CC1J)                                                 ACGB5474
      IF(CC1J(6).EQ.CJ) GO TO 220                                       ACGB5475
      CALL SYM6JA(I,C1J,CC1J)                                           ACGB5476
      CALL SYM6JC(CC1J)                                                 ACGB5477
      IF(CC1J(6).EQ.CJ) GO TO 220                                       ACGB5478
      CALL SYM6JA(I,C1J,CC1J)                                           ACGB5479
      CALL SYM6JD(CC1J)                                                 ACGB5480
      IF(CC1J(6).EQ.CJ) GO TO 220                                       ACGB5481
  213 CONTINUE                                                          ACGB5482
  210 CONTINUE                                                          ACGB5483
C                                                                       ACGB5484
      GO TO 2010                                                        ACGB5485
C                                                                       ACGB5486
  220 CONTINUE                                                          ACGB5487
      L1FIND=L                                                          ACGB5488
      CJ11=CC1J(1)                                                      ACGB5489
      CJ12=CC1J(2)                                                      ACGB5490
      CJ13=CC1J(3)                                                      ACGB5491
      CJ23=CC1J(4)                                                      ACGB5492
      CJ33=CC1J(5)                                                      ACGB5493
C                                                                       ACGB5494
      DO 230 LL=1,N6J                                                   ACGB5495
      IF(I6JF(LL).EQ.0) GO TO 230                                       ACGB5496
      IF(L.EQ.LL) GO TO 230                                             ACGB5497
        DO 232 KJ=1,6                                                   ACGB5498
        C2J(KJ)=C6J(LL,KJ)                                              ACGB5499
  232   CONTINUE                                                        ACGB5500
      DO 233 I=1,6                                                      ACGB5501
      CALL SYM6JA(I,C2J,CC2J)                                           ACGB5502
      IF(CC2J(6).EQ.CJ.AND.                                             ACGB5503
     *   CC2J(1).EQ.CJ23.AND.                                           ACGB5504
     *   CC2J(5).EQ.CJ12)          GO TO 240                            ACGB5505
      CALL SYM6JA(I,C2J,CC2J)                                           ACGB5506
      CALL SYM6JB(CC2J)                                                 ACGB5507
      IF(CC2J(6).EQ.CJ.AND.                                             ACGB5508
     *   CC2J(1).EQ.CJ23.AND.                                           ACGB5509
     *   CC2J(5).EQ.CJ12)          GO TO 240                            ACGB5510
      CALL SYM6JA(I,C2J,CC2J)                                           ACGB5511
      CALL SYM6JC(CC2J)                                                 ACGB5512
      IF(CC2J(6).EQ.CJ.AND.                                             ACGB5513
     *   CC2J(1).EQ.CJ23.AND.                                           ACGB5514
     *   CC2J(5).EQ.CJ12)          GO TO 240                            ACGB5515
      CALL SYM6JA(I,C2J,CC2J)                                           ACGB5516
      CALL SYM6JD(CC2J)                                                 ACGB5517
      IF(CC2J(6).EQ.CJ.AND.                                             ACGB5518
     *   CC2J(1).EQ.CJ23.AND.                                           ACGB5519
     *   CC2J(5).EQ.CJ12)          GO TO 240                            ACGB5520
  233 CONTINUE                                                          ACGB5521
  230 CONTINUE                                                          ACGB5522
C                                                                       ACGB5523
      GO TO 2010                                                        ACGB5524
C                                                                       ACGB5525
  240 CONTINUE                                                          ACGB5526
      L2FIND=LL                                                         ACGB5527
      CJ21=CC2J(2)                                                      ACGB5528
      CJ22=CC2J(3)                                                      ACGB5529
      CJ32=CC2J(4)                                                      ACGB5530
C                                                                       ACGB5531
      DO 1230 LLL=1,N6J                                                 ACGB5532
      IF(I6JF(LLL).EQ.0) GO TO 1230                                     ACGB5533
      IF(L.EQ.LLL.OR.LL.EQ.LLL) GO TO 1230                              ACGB5534
        DO 1232 KJ=1,6                                                  ACGB5535
        C3J(KJ)=C6J(LLL,KJ)                                             ACGB5536
 1232   CONTINUE                                                        ACGB5537
      DO 1233 I=1,6                                                     ACGB5538
      CALL SYM6JA(I,C3J,CC3J)                                           ACGB5539
      IF(CC3J(1).EQ.CJ32.AND.                                           ACGB5540
     *   CC3J(2).EQ.CJ33.AND.                                           ACGB5541
     *   CC3J(4).EQ.CJ11.AND.                                           ACGB5542
     *   CC3J(5).EQ.CJ21.AND.                                           ACGB5543
     *   CC3J(6).EQ.CJ)          GO TO 1240                             ACGB5544
