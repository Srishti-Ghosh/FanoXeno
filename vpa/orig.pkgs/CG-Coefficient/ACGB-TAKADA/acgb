C                                                                       ACGB3091
      DO 100 L=1,N3J                                                    ACGB3092
      IF(I3JF(L).EQ.0) GO TO 100                                        ACGB3093
C                                                                       ACGB3094
      DO 110 KJ=1,3                                                     ACGB3095
      DO 110 KM=1,2                                                     ACGB3096
      H3JM(KJ,KM)=C3JM(L,KJ,KM)                                         ACGB3097
  110 CONTINUE                                                          ACGB3098
C                                                                       ACGB3099
      DO 120 I=1,6                                                      ACGB3100
      CALL SYM3JA(I,H3JM,HH3JM,NNPHJ,HHPHJ)                             ACGB3101
      IF(HH3JM(3,1).EQ.'0') THEN                                        ACGB3102
        I3JF(L)=0                                                       ACGB3103
        IF(NNPHJ.NE.0) THEN                                             ACGB3104
          DO 121 KK=1,NNPHJ                                             ACGB3105
          C3PHJ(KK+N3PHJ)=HHPHJ(KK)                                     ACGB3106
  121     CONTINUE                                                      ACGB3107
        END IF                                                          ACGB3108
        N3PHJ=N3PHJ+NNPHJ                                               ACGB3109
C                                                                       ACGB3110
        N3PHJ=N3PHJ+1                                                   ACGB3111
        C3PHJ(N3PHJ)=HH3JM(1,1)                                         ACGB3112
        N3PHM=N3PHM+1                                                   ACGB3113
        C3PHM(N3PHM)=CHSIGN(HH3JM(1,2))                                 ACGB3114
C                                                                       ACGB3115
        N3DE=N3DE+1                                                     ACGB3116
        H3DE(N3DE)='#'//HH3JM(1,1)                                      ACGB3117
C                                                                       ACGB3118
        NDELJ=NDELJ+1                                                   ACGB3119
        CDELJ(NDELJ,1)=HH3JM(1,1)                                       ACGB3120
        CDELJ(NDELJ,2)=HH3JM(2,1)                                       ACGB3121
C                                                                       ACGB3122
        NDELM=NDELM+1                                                   ACGB3123
        IDELF(NDELM)=1                                                  ACGB3124
        CDELM(NDELM,1)=HH3JM(1,2)                                       ACGB3125
        CDELM(NDELM,2)=CHSIGN(HH3JM(2,2))                               ACGB3126
C                                                                       ACGB3127
        GO TO 100                                                       ACGB3128
      END IF                                                            ACGB3129
  120 CONTINUE                                                          ACGB3130
C                                                                       ACGB3131
  100 CONTINUE                                                          ACGB3132
C                                                                       ACGB3133
      RETURN                                                            ACGB3134
      END                                                               ACGB3135
