      IF(CC3J(1).EQ.CJ32.AND.                                           ACGB5547
     *   CC3J(2).EQ.CJ33.AND.                                           ACGB5548
     *   CC3J(4).EQ.CJ11.AND.                                           ACGB5549
     *   CC3J(5).EQ.CJ21.AND.                                           ACGB5550
     *   CC3J(6).EQ.CJ)          GO TO 1240                             ACGB5551
      CALL SYM6JA(I,C3J,CC3J)                                           ACGB5552
      CALL SYM6JC(CC3J)                                                 ACGB5553
      IF(CC3J(1).EQ.CJ32.AND.                                           ACGB5554
     *   CC3J(2).EQ.CJ33.AND.                                           ACGB5555
     *   CC3J(4).EQ.CJ11.AND.                                           ACGB5556
     *   CC3J(5).EQ.CJ21.AND.                                           ACGB5557
     *   CC3J(6).EQ.CJ)          GO TO 1240                             ACGB5558
      CALL SYM6JA(I,C3J,CC3J)                                           ACGB5559
      CALL SYM6JD(CC3J)                                                 ACGB5560
      IF(CC3J(1).EQ.CJ32.AND.                                           ACGB5561
     *   CC3J(2).EQ.CJ33.AND.                                           ACGB5562
     *   CC3J(4).EQ.CJ11.AND.                                           ACGB5563
     *   CC3J(5).EQ.CJ21.AND.                                           ACGB5564
     *   CC3J(6).EQ.CJ)          GO TO 1240                             ACGB5565
 1233 CONTINUE                                                          ACGB5566
 1230 CONTINUE                                                          ACGB5567
C                                                                       ACGB5568
      GO TO 2010                                                        ACGB5569
C                                                                       ACGB5570
 1240 CONTINUE                                                          ACGB5571
      L3FIND=LLL                                                        ACGB5572
      CJ31=CC3J(3)                                                      ACGB5573
C                                                                       ACGB5574
C   *** TO CHECK AND REARRANGE NUMERATORS AND DENOMINATORS              ACGB5575
C                                                                       ACGB5576
      CDE(NDE+1)='#'//CJ                                                ACGB5577
      CDE(NDE+2)='#'//CJ                                                ACGB5578
      NDE=NDE+2                                                         ACGB5579
C                                                                       ACGB5580
      CALL RENUDE                                                       ACGB5581
C                                                                       ACGB5582
      IF(NNU.NE.0) THEN                                                 ACGB5583
        DO 251 KK=1,NNU                                                 ACGB5584
        IF(CNU(KK)(2:10).EQ.CJ) GO TO 2020                              ACGB5585
  251   CONTINUE                                                        ACGB5586
      END IF                                                            ACGB5587
C                                                                       ACGB5588
      IF(NDE.NE.0) THEN                                                 ACGB5589
        DO 252 KK=1,NDE                                                 ACGB5590
        IF(CDE(KK)(2:10).EQ.CJ) GO TO 2020                              ACGB5591
  252   CONTINUE                                                        ACGB5592
      END IF                                                            ACGB5593
C                                                                       ACGB5594
C   *** TO CHECK WHETHER THERE ARE REMAINING CJ IN (6-J)'S              ACGB5595
C                                                                       ACGB5596
      DO 255 L=1,N6J                                                    ACGB5597
      IF(I6JF(L).EQ.0) GO TO 255                                        ACGB5598
      IF(L.NE.L1FIND.AND.L.NE.L2FIND.AND.L.NE.L3FIND) THEN              ACGB5599
        DO 256 KJ=1,6                                                   ACGB5600
        IF(CJ.EQ.C6J(L,KJ)) GO TO 2020                                  ACGB5601
  256   CONTINUE                                                        ACGB5602
