C                                                                       ACGB5644
      IF(MN1.EQ.1.OR.MN1.EQ.3) GO TO 2020                               ACGB5645
      IF(MN1.EQ.2) GO TO 280                                            ACGB5646
C                                                                       ACGB5647
      DO 270 I=1,NTANG                                                  ACGB5648
      IF(ITANGF(I).EQ.0) GO TO 270                                      ACGB5649
      DO 271 KK=1,3                                                     ACGB5650
      IF(CTANG(I,KK).EQ.CJ) GO TO 272                                   ACGB5651
  271 CONTINUE                                                          ACGB5652
  270 CONTINUE                                                          ACGB5653
      GO TO 2020                                                        ACGB5654
C                                                                       ACGB5655
  272 CONTINUE                                                          ACGB5656
      DO 275 KKK=1,3                                                    ACGB5657
      IF(KKK.EQ.KK) GO TO 275                                           ACGB5658
      NPHJ=NPHJ+1                                                       ACGB5659
      CPHJ(NPHJ)=CTANG(I,KKK)                                           ACGB5660
      NPHJ=NPHJ+1                                                       ACGB5661
      CPHJ(NPHJ)=CTANG(I,KKK)                                           ACGB5662
  275 CONTINUE                                                          ACGB5663
C                                                                       ACGB5664
  280 CONTINUE                                                          ACGB5665
C                                                                       ACGB5666
      ISUMF(K)=0                                                        ACGB5667
      I6JF(L1FIND)=0                                                    ACGB5668
      I6JF(L2FIND)=0                                                    ACGB5669
      I6JF(L3FIND)=0                                                    ACGB5670
C                                                                       ACGB5671
      DO 281 I=1,NTANG                                                  ACGB5672
      IF(ITANGF(I).EQ.0) GO TO 281                                      ACGB5673
      DO 282 KK=1,3                                                     ACGB5674
      IF(CTANG(I,KK).EQ.CJ) THEN                                        ACGB5675
        ITANGF(I)=0                                                     ACGB5676
        GO TO 281                                                       ACGB5677
      END IF                                                            ACGB5678
  282 CONTINUE                                                          ACGB5679
  281 CONTINUE                                                          ACGB5680
C                                                                       ACGB5681
      N9J=N9J+1                                                         ACGB5682
      I9JF(N9J)=1                                                       ACGB5683
      C9J(N9J,1)=CJ11                                                   ACGB5684
      C9J(N9J,2)=CJ12                                                   ACGB5685
      C9J(N9J,3)=CJ13                                                   ACGB5686
      C9J(N9J,4)=CJ21                                                   ACGB5687
      C9J(N9J,5)=CJ22                                                   ACGB5688
      C9J(N9J,6)=CJ23                                                   ACGB5689
      C9J(N9J,7)=CJ31                                                   ACGB5690
      C9J(N9J,8)=CJ32                                                   ACGB5691
      C9J(N9J,9)=CJ33                                                   ACGB5692
